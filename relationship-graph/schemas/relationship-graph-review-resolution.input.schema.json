{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Mechanics130/costar_agent/main/relationship-graph/schemas/relationship-graph-review-resolution.input.schema.json",
  "title": "Relationship Graph Review Resolution Input",
  "type": "object",
  "additionalProperties": false,
  "required": ["graph_result", "review_decisions"],
  "properties": {
    "skill": { "type": "string" },
    "version": { "type": "string" },
    "graph_result": { "type": "object" },
    "review_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["final_action"],
        "properties": {
          "source_person_ref": { "type": "string" },
          "source_person_name": { "type": "string" },
          "target_person_ref": { "type": "string" },
          "target_person_name": { "type": "string" },
          "final_action": {
            "type": "string",
            "enum": ["confirm", "reject", "downgrade", "reclassify", "defer"]
          },
          "corrected_relation_type": { "type": "string" },
          "note": { "type": "string" }
        }
      }
    },
    "graph_review_store_path": { "type": "string" },
    "operator": { "type": "string" },
    "notes": { "type": "string" },
    "partial_commit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "strategy": { "type": "string", "enum": ["selection_only", "safe_edges_only", "review_required_only"] },
        "selected_edge_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "selected_pairs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "source_person_ref": { "type": "string" },
              "target_person_ref": { "type": "string" }
            }
          }
        },
        "note": { "type": "string" }
      }
    },
    "options": {
      "type": "object",
      "properties": {
        "write_store": { "type": "boolean" }
      }
    }
  }
}
