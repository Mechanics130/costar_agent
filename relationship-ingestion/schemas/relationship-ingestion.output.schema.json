{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://costar.dev/schemas/relationship-ingestion.output.schema.json",
  "title": "Relationship Ingestion Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "skill",
    "version",
    "status",
    "source",
    "policy",
    "source_summary",
    "interaction_summary",
    "detected_people",
    "resolved_people",
    "profile_updates",
    "person_profiles",
    "relationship_edges",
    "todos",
    "evidence",
    "review_flags",
    "review_bundle"
  ],
  "properties": {
    "skill": { "type": "string", "const": "relationship-ingestion" },
    "version": { "type": "string" },
    "status": { "type": "string", "enum": ["success", "needs_review"] },
    "source": { "type": "string", "enum": ["llm"] },
    "source_label": { "type": "string" },
    "run_directory": { "type": ["string", "null"] },
    "model": { "type": "object" },
    "policy": { "type": "object" },
    "source_summary": { "type": "object" },
    "interaction_summary": { "type": "object" },
    "detected_people": { "type": "array", "items": { "type": "object" } },
    "resolved_people": { "type": "array", "items": { "type": "object" } },
    "profile_updates": { "type": "array", "items": { "type": "object" } },
    "person_profiles": { "type": "array", "items": { "type": "object" } },
    "relationship_edges": { "type": "array", "items": { "type": "object" } },
    "todos": { "type": "array", "items": { "type": "object" } },
    "evidence": { "type": "array", "items": { "type": "object" } },
    "review_flags": { "type": "array", "items": { "type": "object" } },
    "review_bundle": { "type": "object" },
    "notes": { "type": "string" }
  }
}
