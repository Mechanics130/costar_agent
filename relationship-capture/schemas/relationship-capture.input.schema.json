{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Mechanics130/costar_agent/main/relationship-capture/schemas/relationship-capture.input.schema.json",
  "title": "Relationship Capture Input",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "request_id": { "type": ["string", "null"] },
    "goal": { "type": "string" },
    "target_people": { "type": "array", "items": { "type": "string" } },
    "focus_people": { "type": "array", "items": { "type": "string" } },
    "focus_instruction": { "type": "string" },
    "existing_people": { "type": "array", "items": { "type": "object" } },
    "sources": { "type": "array", "items": { "type": "object" } },
    "options": { "type": "object" },
    "model_config": { "type": "object" },
    "ingestion_result": { "type": "object" },
    "review_decisions": { "type": "array", "items": { "type": "object" } },
    "existing_profiles": { "type": "array", "items": { "type": "object" } },
    "profile_store_path": { "type": "string" },
    "view_store_path": { "type": "string" },
    "view_markdown_dir": { "type": "string" },
    "graph_review_store_path": { "type": "string" },
    "operator": { "type": "string" },
    "notes": { "type": "string" },
    "review_options": { "type": "object" }
  },
  "anyOf": [
    { "required": ["sources"] },
    { "required": ["ingestion_result"] }
  ]
}
